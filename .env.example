# Copy to .env and adjust. Prefix for all vars: CRYPTO_BOT_

CRYPTO_BOT_LOG_LEVEL=INFO
CRYPTO_BOT_DEFAULT_SYMBOL=BTC/USDT
CRYPTO_BOT_PAPER_TRADING=true

# CCXT public OHLCV needs no keys; add for private endpoints later
CRYPTO_BOT_CCXT_EXCHANGE=binance
CRYPTO_BOT_CCXT_TIMEFRAME=1m
CRYPTO_BOT_CCXT_POLL_INTERVAL=2
# CRYPTO_BOT_CCXT_API_KEY=
# CRYPTO_BOT_CCXT_API_SECRET=
