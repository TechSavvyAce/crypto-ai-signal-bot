# Copy to .env and adjust. Prefix for all vars: CRYPTO_BOT_

CRYPTO_BOT_LOG_LEVEL=INFO
CRYPTO_BOT_DEFAULT_SYMBOL=BTC/USDT
CRYPTO_BOT_PAPER_TRADING=true

# CCXT public OHLCV needs no keys; add for private endpoints later
CRYPTO_BOT_CCXT_EXCHANGE=binance
CRYPTO_BOT_CCXT_TIMEFRAME=1m
CRYPTO_BOT_CCXT_POLL_INTERVAL=2
# CRYPTO_BOT_CCXT_API_KEY=
# CRYPTO_BOT_CCXT_API_SECRET=

# Live spot orders (crypto-ccxt-daemon --execution ccxt-live): MUST be true after reading README "Live trading"
# CRYPTO_BOT_LIVE_TRADING_ACK=false

# --- Secrets (Phase 6) ---
# Never commit a real `.env` file or paste keys into chat/logs.
# Prefer exchange API keys with **withdrawal disabled** + IP allowlist; scope permissions narrowly.
# Rotate keys if leaked; use env vars / secret manager in production, not hardcoded strings.

# Model registry JSON (name@version → artifact path + fingerprint). Used by crypto-model-registry and daemons.
# CRYPTO_BOT_MODEL_REGISTRY_FILE=model_registry.json

# Risk (optional; prefix CRYPTO_BOT_RISK_)
# CRYPTO_BOT_RISK_MAX_DAILY_LOSS_FRAC=0.02
# CRYPTO_BOT_RISK_MAX_POSITION_FRAC_EQUITY=0.1
# CRYPTO_BOT_RISK_MAX_LEVERAGE=3
# CRYPTO_BOT_RISK_STOP_LOSS_FRAC=0.01
# CRYPTO_BOT_RISK_MIN_ORDER_NOTIONAL_QUOTE=10
# CRYPTO_BOT_RISK_BALANCE_CLIP_BUFFER_FRAC=0.002
